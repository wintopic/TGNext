---
import '../assets/normalize.css'
import '../assets/style.css'
import '../assets/global.css'
import { SEO } from 'astro-seo'
import { getEnv } from '../lib/env'
import { getUiLabels } from '../lib/i18n'
import { getChannelOptions, getChannelSetting } from '../lib/settings'
import backToTopIcon from '../assets/back-to-top.svg'

const { SITE_URL, RSS_URL, RSS_PREFIX } = Astro.locals
const { channel } = Astro.props

const labels = getUiLabels(Astro)
const channelSetting = getChannelSetting(Astro)
const channelOptions = getChannelOptions(Astro)
const channelList = channelOptions.list
const currentChannel = channelOptions.current
const currentChannelKey = currentChannel?.toLowerCase() ?? ''
const canSwitchChannel = channelList.length > 1 && channelSetting.source !== 'env'
const orderedChannels = currentChannel
  ? [currentChannel, ...channelList.filter((name) => name.toLowerCase() !== currentChannelKey)]
  : [...channelList]
const visibleChannels = orderedChannels.slice(0, 3)
const overflowChannels = orderedChannels.slice(3)
const showTabbar = canSwitchChannel && orderedChannels.length > 1
const redirectValue = `${Astro.url.pathname}${Astro.url.search}`

const locale = 'zh-CN'

const seo = channel?.seo
const reqPathname = Astro.url.pathname.replace(/\/$/, '')
const canonical = SITE_URL.startsWith('http') ? new URL(SITE_URL).origin + reqPathname : Astro.url.origin + reqPathname

const { origin, pathname } = new URL(canonical)
const twitter = getEnv(import.meta.env, Astro, 'TWITTER')

const seoParams = {
  title: seo?.title,
  description: seo?.text ?? channel?.description,
  canonical,
  noindex: seo?.noindex ?? getEnv(import.meta.env, Astro, 'NOINDEX'),
  nofollow: seo?.nofollow ?? getEnv(import.meta.env, Astro, 'NOFOLLOW'),
  openGraph: {
    basic: {
      type: 'website',
      title: channel?.title ?? '',
      url: canonical,
      image: channel?.avatar ? channel.avatar : origin + '/favicon.ico',
    },
    optional: {
      description: seo?.text ?? channel?.description,
      locale,
    },
  },
  extend: {
    link: [
      {
        rel: 'icon',
        href: channel?.avatar
          ? `https://wsrv.nl/?w=64&h=64&fit=cover&mask=circle&url=ssl:${channel?.avatar?.replace(/^https?:\/\//, '')}`
          : '/favicon.svg',
      },
    ],
  },
}

const GOOGLE_SEARCH_SITE = getEnv(import.meta.env, Astro, 'GOOGLE_SEARCH_SITE')
const searchAction = GOOGLE_SEARCH_SITE ? 'https://www.google.com/search' : '/search'

const HEADER_INJECT = getEnv(import.meta.env, Astro, 'HEADER_INJECT')
const FOOTER_INJECT = getEnv(import.meta.env, Astro, 'FOOTER_INJECT')
const TAGS = getEnv(import.meta.env, Astro, 'TAGS')
const LINKS = getEnv(import.meta.env, Astro, 'LINKS')

const tags = (TAGS || '')
  .split(',')
  .map((tag) => tag.trim())
  .filter(Boolean)

const links = (LINKS || '')
  .split(';')
  .filter(Boolean)
  .map((link) => {
    link = link.split(',')
    return {
      title: link[0],
      href: link[1],
    }
  })

const navs = (getEnv(import.meta.env, Astro, 'NAVS') || '')
  .split(';')
  .filter(Boolean)
  .map((link) => {
    link = link.split(',')
    return {
      title: link[0],
      href: link[1],
    }
  })

const searchQuery = Astro.url.searchParams.get('q') || ''
const pathQuery = Astro.params?.q ? decodeURIComponent(Astro.params.q) : ''
const currentQuery = searchQuery || pathQuery
const currentTag = currentQuery?.startsWith('#') ? currentQuery.replace('#', '') : ''
---

<!doctype html>
<html
  lang={locale}
  data-theme="mono"
  data-mode="light"
  data-mode-preference="system"
  data-layout="card"
  data-tabbar={showTabbar ? 'true' : 'false'}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f7f9fb" />
    <link rel="alternate" type="application/rss+xml" title={`${RSS_PREFIX}${channel?.title}`} href={RSS_URL} />
    <style is:inline>
      @view-transition {
        navigation: auto;
      }
    </style>
    <script is:inline>
      ;(() => {
        const doc = document.documentElement
        const allowedLayouts = ['card', 'grid', 'masonry']
        const storedMode = localStorage.getItem('tgnext-mode') || 'system'
        const storedLayoutRaw = localStorage.getItem('tgnext-layout')
        const storedLayout = allowedLayouts.includes(storedLayoutRaw) ? storedLayoutRaw : 'card'
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        const resolvedMode = storedMode === 'system' ? (systemDark ? 'dark' : 'light') : storedMode

        doc.dataset.mode = resolvedMode
        doc.dataset.modePreference = storedMode
        doc.dataset.layout = storedLayout
      })()
    </script>
    <SEO
      titleTemplate={`%s | ${channel?.title} · TGNext`}
      titleDefault={[channel?.title, seoParams.description, 'TGNext'].filter(Boolean).join(' · ')}
      twitter={{
        card: 'summary_large_image',
        creator: twitter ? `@${twitter}` : undefined,
      }}
      {...seoParams}
    />
    <Fragment set:html={HEADER_INJECT} />
  </head>

  <body id="top">
    <div class="app-shell">
      <header class="topbar glass-bar">
        <div class="topbar-content">
          <div class="topbar-brand">
            <a class="brand" href={SITE_URL} title="TGNext">TGNext</a>
            <div class="brand-subtitle">{channel?.title}</div>
          </div>

          <nav class="topbar-nav" aria-label="主导航">
            <a href={SITE_URL} title={labels.home} class={`nav-link ${pathname === '/' ? 'current' : ''}`}>
              {labels.home}
            </a>
            {
              TAGS ? (
                <a
                  href={`${SITE_URL}tags`}
                  title={labels.tags}
                  class={`nav-link ${pathname === '/tags' ? 'current' : ''}`}
                >
                  {labels.tags}
                </a>
              ) : null
            }
            {
              LINKS ? (
                <a
                  href={`${SITE_URL}links`}
                  title={labels.links}
                  class={`nav-link ${pathname === '/links' ? 'current' : ''}`}
                >
                  {labels.links}
                </a>
              ) : null
            }
            <a
              href={`${SITE_URL}settings`}
              title={labels.settings}
              class={`nav-link ${pathname === '/settings' ? 'current' : ''}`}
            >
              {labels.settings}
            </a>
            <a
              href={RSS_URL}
              title={labels.rss}
              class="nav-link"
              target="_blank"
              rel="alternate"
              type="application/rss+xml"
            >
              RSS
            </a>
            {
              navs.map((nav) => (
                <a href={nav.href} title={nav.title} target="_blank" rel="noopener" class="nav-link">
                  {nav.title}
                </a>
              ))
            }
          </nav>

          <form
            class="search-form search-form-inline topbar-search"
            action={searchAction}
            method="get"
            data-search-form
          >
            {GOOGLE_SEARCH_SITE ? <input type="hidden" name="as_sitesearch" value={GOOGLE_SEARCH_SITE} /> : null}
            <label class="search-label" for="search-input">{labels.search}</label>
            <div class="search-input-wrap">
              <input
                id="search-input"
                type="text"
                name="q"
                placeholder={labels.searchPlaceholder}
                defaultValue={currentQuery}
              />
              <button type="submit" class="icon-button search-submit" aria-label={labels.search}>
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M15.5 15.5L20 20M17 10.5a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </button>
            </div>
            <button type="button" class="icon-button search-trigger" aria-label={labels.search}>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M15.5 15.5L20 20M17 10.5a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
          </form>
        </div>
      </header>

      <main class="main">
        <slot name="header" />

        {(tags.length > 0 || links.length > 0) && (
          <div class="meta-panel">
            {tags.length > 0 && (
              <div class="meta-section">
                <div class="block-title">{labels.tags}</div>
                <div class="tag-list">
                  {tags.map((tag) => (
                    <a href={`/search/%23${tag}`} class={`tag-chip ${currentTag === tag ? 'active' : ''}`} title={tag}>
                      #{tag}
                    </a>
                  ))}
                </div>
              </div>
            )}

            {links.length > 0 && (
              <div class="meta-section">
                <div class="block-title">{labels.links}</div>
                <div class="link-list">
                  {links.map((link) => (
                    <a href={link.href} class="link-chip" target="_blank" rel="noopener" title={link.title}>
                      {link.title}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        <slot />
      </main>
    </div>

    {
      showTabbar && (
        <>
          <nav class="tabbar glass-bar" aria-label={labels.quickSwitchTitle}>
            <form class="tabbar-content" action="/settings/switch" method="post">
              <input type="hidden" name="redirect" value={redirectValue} />
              {visibleChannels.map((name) => (
                <button
                  type="submit"
                  name="channel"
                  value={name}
                  class={`tabbar-item ${name.toLowerCase() === currentChannelKey ? 'active' : ''}`}
                >
                  <span class="tabbar-label">{name}</span>
                </button>
              ))}
              {overflowChannels.length > 0 && (
                <button
                  type="button"
                  class="tabbar-item tabbar-more"
                  popovertarget="channel-more"
                  popovertargetaction="show"
                  aria-label={labels.moreChannels}
                >
                  <span class="tabbar-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                      <path
                        d="M6 7.5h12M6 12h12M6 16.5h12"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.6"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      ></path>
                    </svg>
                  </span>
                  <span class="tabbar-label">{labels.more}</span>
                </button>
              )}
            </form>
          </nav>
          {overflowChannels.length > 0 && (
            <div id="channel-more" class="tabbar-popover glass-panel" popover>
              <div class="tabbar-popover-head">{labels.moreChannels}</div>
              <form class="tabbar-popover-list" action="/settings/switch" method="post">
                <input type="hidden" name="redirect" value={redirectValue} />
                {overflowChannels.map((name) => (
                  <button
                    type="submit"
                    name="channel"
                    value={name}
                    class={`tabbar-popover-item ${name.toLowerCase() === currentChannelKey ? 'active' : ''}`}
                  >
                    {name}
                  </button>
                ))}
              </form>
              <button class="tabbar-popover-close" type="button" popovertarget="channel-more" popovertargetaction="hide">
                {labels.close}
              </button>
            </div>
          )}
        </>
      )
    }

    <a href="#top" id="back-to-top" aria-label="返回顶部">
      <img {...backToTopIcon} alt="返回顶部" />
    </a>
    <Fragment set:html={FOOTER_INJECT} />

    <script is:inline>
      ;(() => {
        const doc = document.documentElement
        const modeButtons = document.querySelectorAll('[data-mode-value]')
        const layoutButtons = document.querySelectorAll('[data-layout-value]')
        const searchForm = document.querySelector('[data-search-form]')
        const searchInput = document.querySelector('#search-input')
        const media = window.matchMedia('(prefers-color-scheme: dark)')
        const mobileQuery = window.matchMedia('(max-width: 560px)')

        function resolveMode(modePreference) {
          if (modePreference === 'system') {
            return media.matches ? 'dark' : 'light'
          }
          return modePreference
        }

        function updateButtons() {
          const modePreference = doc.dataset.modePreference || 'system'
          const layout = doc.dataset.layout || 'card'

          modeButtons.forEach((button) => {
            button.setAttribute('aria-pressed', button.dataset.modeValue === modePreference)
          })

          layoutButtons.forEach((button) => {
            button.setAttribute('aria-pressed', button.dataset.layoutValue === layout)
          })
        }

        function setMode(modePreference) {
          localStorage.setItem('tgnext-mode', modePreference)
          doc.dataset.modePreference = modePreference
          doc.dataset.mode = resolveMode(modePreference)
          updateButtons()
        }

        function setLayout(layout) {
          localStorage.setItem('tgnext-layout', layout)
          doc.dataset.layout = layout
          updateButtons()
        }

        function updateSearchMode() {
          if (!searchForm)
            return
          searchForm.dataset.collapsed = mobileQuery.matches ? 'true' : 'false'
        }

        document.addEventListener('click', (event) => {
          const modeButton = event.target.closest('[data-mode-value]')
          if (modeButton) {
            setMode(modeButton.dataset.modeValue)
            return
          }

          const layoutButton = event.target.closest('[data-layout-value]')
          if (layoutButton) {
            setLayout(layoutButton.dataset.layoutValue)
          }
        })

        media.addEventListener('change', (event) => {
          if ((doc.dataset.modePreference || 'system') === 'system') {
            doc.dataset.mode = event.matches ? 'dark' : 'light'
          }
        })

        if (mobileQuery) {
          mobileQuery.addEventListener('change', updateSearchMode)
          updateSearchMode()
        }

        if (searchForm) {
          searchForm.addEventListener('click', (event) => {
            if (searchForm.dataset.collapsed !== 'true')
              return
            const trigger = event.target.closest('.search-trigger')
            if (!trigger)
              return
            event.preventDefault()
            event.stopPropagation()
            searchForm.dataset.collapsed = 'false'
            requestAnimationFrame(() => {
              searchInput?.focus()
            })
          })

          document.addEventListener('click', (event) => {
            if (searchForm.dataset.collapsed === 'true')
              return
            if (searchForm.contains(event.target))
              return
            searchForm.dataset.collapsed = mobileQuery.matches ? 'true' : 'false'
          })
        }

        updateButtons()
      })()
    </script>
  </body>
</html>
