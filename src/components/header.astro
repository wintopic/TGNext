---
import { getEnv } from '../lib/env'
import { getUiLabels } from '../lib/i18n'
import voidFile from '../assets/void.png'
import rss from '../assets/rss.svg'
import podcast from '../assets/podcast.svg'
import twitter from '../assets/twitter.svg'
import github from '../assets/github.svg'
import discord from '../assets/discord.svg'
import telegram from '../assets/telegram.svg'
import mastodon from '../assets/mastodon.svg'
import bluesky from '../assets/bluesky.svg'

const { SITE_URL, RSS_URL } = Astro.locals
const { channel } = Astro.props

const labels = getUiLabels(Astro)

const PODCAST = getEnv(import.meta.env, Astro, 'PODCAST') ?? getEnv(import.meta.env, Astro, 'PODCASRT')
const TWITTER = getEnv(import.meta.env, Astro, 'TWITTER')
const GITHUB = getEnv(import.meta.env, Astro, 'GITHUB')
const TELEGRAM = getEnv(import.meta.env, Astro, 'TELEGRAM')
const DISCORD = getEnv(import.meta.env, Astro, 'DISCORD')
const MASTODON = getEnv(import.meta.env, Astro, 'MASTODON')
const BLUESKY = getEnv(import.meta.env, Astro, 'BLUESKY')

const staticProxy = getEnv(import.meta.env, Astro, 'STATIC_PROXY') ?? '/static/'
const hideDescription = getEnv(import.meta.env, Astro, 'HIDE_DESCRIPTION')
---

<div class="profile-card">
  <div class="profile-head">
    <a href={SITE_URL} title={channel?.title} class="profile-avatar">
      <img
        src={channel?.avatar?.startsWith('http') ? staticProxy + channel?.avatar : voidFile.src}
        alt={channel?.title}
        loading="eager"
      />
    </a>
    <div class="profile-info">
      <div class="profile-title-row">
        <a href={SITE_URL} class="profile-title" title={channel?.title}>
          {channel?.title}
        </a>
        <span class="profile-badge">TGNext</span>
      </div>
      <div class="profile-actions">
        <a href={RSS_URL} target="_blank" rel="alternate" type="application/rss+xml" title={labels.rss} class="icon-button">
          <img {...rss} alt="RSS" />
        </a>

        {
          PODCAST && (
            <a href={PODCAST} target="_blank" title="播客" class="icon-button">
              <img {...podcast} alt="播客" />
            </a>
          )
        }

        {
          TWITTER && TWITTER.length > 0 && (
            <a href={`https://twitter.com/${TWITTER}`} title="X / Twitter" target="_blank" class="icon-button">
              <img {...twitter} alt={`X：${TWITTER}`} />
            </a>
          )
        }

        {
          GITHUB && GITHUB.length > 0 && (
            <a href={`https://github.com/${GITHUB}`} title="GitHub" target="_blank" class="icon-button">
              <img {...github} alt={`GitHub：${GITHUB}`} />
            </a>
          )
        }

        {
          TELEGRAM && TELEGRAM.length > 0 && (
            <a href={`https://t.me/${TELEGRAM}`} title="Telegram" target="_blank" class="icon-button">
              <img {...telegram} alt={`Telegram：${TELEGRAM}`} />
            </a>
          )
        }

        {
          DISCORD && DISCORD.length > 0 && (
            <a href={DISCORD} title="Discord" target="_blank" class="icon-button">
              <img {...discord} alt="Discord" />
            </a>
          )
        }

        {
          MASTODON && MASTODON.length > 0 && (
            <a href={`https://${MASTODON}`} title="Mastodon" target="_blank" class="icon-button">
              <img {...mastodon} alt={`Mastodon：${MASTODON}`} />
            </a>
          )
        }

        {
          BLUESKY && BLUESKY.length > 0 && (
            <a href={`https://bsky.app/profile/${BLUESKY}`} title="BlueSky" target="_blank" class="icon-button">
              <img {...bluesky} alt={`BlueSky：${BLUESKY}`} />
            </a>
          )
        }
      </div>
    </div>
  </div>

  {
    hideDescription !== 'true' && channel?.descriptionHTML && channel?.descriptionHTML.length > 0 && (
      <div class="profile-bio content" set:html={channel?.descriptionHTML} />
    )
  }
</div>
