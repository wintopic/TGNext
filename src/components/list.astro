---
import Layout from '../layouts/base.astro'
import Header from '../components/header.astro'
import Item from '../components/item.astro'
import { getUiLabels } from '../lib/i18n'
import type { ChannelInfo, ChannelPost } from '../lib/types'

const { SITE_URL } = Astro.locals
const {
  channel,
  before = true,
  after = true,
  isItem = false,
  query = null,
  emptyTitle,
  emptyHint,
} = Astro.props as {
  after?: boolean
  before?: boolean
  channel: ChannelInfo
  emptyHint?: string
  emptyTitle?: string
  isItem?: boolean
  query?: string | null
}
const posts: ChannelPost[] = channel.posts ?? []
const labels = getUiLabels(Astro)

const beforeCursor = posts[posts.length - 1]?.id
const afterCursor = posts[0]?.id
const beforeCursorNumber = Number(beforeCursor || 0)
// const cursor = +Astro.params.cursor

const hasSearchContext = query !== null && query !== undefined
const searchQuery = typeof query === 'string' ? query.trim() : ''
const isTagQuery = searchQuery.startsWith('#')
const displayQuery = isTagQuery ? searchQuery.replace(/^#/, '') : searchQuery
const showFeedIntro = !isItem && !hasSearchContext && posts.length > 0
const resolvedEmptyTitle =
  emptyTitle ??
  (hasSearchContext && searchQuery ? labels.searchEmpty : hasSearchContext ? labels.search : labels.noPosts)
const resolvedEmptyHint = emptyHint ?? (hasSearchContext && !searchQuery ? labels.searchTip : '')
---

<Layout channel={channel} id="main-container">
  <slot name="header">
    <Header channel={channel} />
  </slot>
  {
    hasSearchContext && (
      <div class="search-header">
        <div>
          <div class="search-title">{isTagQuery ? labels.tagResults : labels.searchResults}</div>
          {searchQuery ? (
            <div class="search-query">
              <span class="search-query-label">{labels.search}</span>
              <span class="search-query-value">{displayQuery}</span>
            </div>
          ) : (
            <div class="search-query search-query-empty">{labels.searchPlaceholder}</div>
          )}
        </div>
        <div class="search-meta">{searchQuery ? `${posts.length} · ${labels.searchResults}` : labels.searchTip}</div>
        <div class="search-actions">
          <a href="/search" class="ghost-button">
            {labels.clear}
          </a>
          <a href={SITE_URL} class="ghost-button">
            {labels.back}
          </a>
        </div>
      </div>
    )
  }

  {
    showFeedIntro && (
      <section class="feed-intro glass-panel">
        <div class="feed-intro-kicker">{labels.feedTitle}</div>
        <div class="feed-intro-title">{channel?.title || labels.feedTitle}</div>
        <div class="feed-intro-text">{labels.feedHint}</div>
        <div class="feed-intro-meta">
          <span>{channel?.title || '当前频道'}</span>
          <span>{posts.length} 条内容</span>
        </div>
      </section>
    )
  }

  {
    posts.length > 0 ? (
      <div class={`items ${isItem ? 'items-detail' : 'items-feed'}`}>
        {posts.map((post, index) => (
          <Item post={post} isItem={isItem} featured={!isItem && index === 0 && !hasSearchContext} />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <div class="empty-title">{resolvedEmptyTitle}</div>
        {(resolvedEmptyHint ?? '').length > 0 && <div class="empty-hint">{resolvedEmptyHint}</div>}
      </div>
    )
  }

  <div class="pages-container">
    {
      before && beforeCursorNumber > 1 ? (
        <a href={`${SITE_URL}before/${beforeCursor}`} title={labels.before} class="page">
          {labels.before}
        </a>
      ) : (
        <span class="page-placeholder">&nbsp;</span>
      )
    }

    <div class="pages-info"></div>
    {
      after && afterCursor ? (
        <a href={`${SITE_URL}after/${afterCursor}`} title={labels.after} class="page">
          {labels.after}
        </a>
      ) : (
        <span class="page-placeholder">&nbsp;</span>
      )
    }
  </div>
</Layout>
