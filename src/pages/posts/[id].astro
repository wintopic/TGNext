---
import { getEnv } from '../../lib/env'
import { getUiLabels } from '../../lib/i18n'
import voidFile from '../../assets/void.png'
import List from '../../components/list.astro'
import { getChannelInfo } from '../../lib/telegram'

const { SITE_URL } = Astro.locals

const labels = getUiLabels(Astro)
const channelInfo = await getChannelInfo(Astro)

const post = await getChannelInfo(Astro, {
  type: 'post',
  id: Astro.params.id,
})

const isFiltered = post?.filtered || !post?.id
const channel = {
  ...(channelInfo || {}),
  posts: isFiltered ? [] : [post],
  seo: isFiltered ? { title: labels.filtered } : post,
}

const staticProxy = getEnv(import.meta.env, Astro, 'STATIC_PROXY') ?? '/static/'
---

<List
  channel={channel}
  before={false}
  after={false}
  isItem={true}
  emptyTitle={labels.filtered}
  emptyHint={labels.filteredHint}
>
  <div slot="header" id="breadcrumb">
    <img
      src={channel?.avatar?.startsWith('http') ? staticProxy + channel?.avatar : voidFile.src}
      alt={channel?.title}
      loading="eager"
      class="breadcrumb-avatar"
    />
    <div class="breadcrumb-title">
      <a href={SITE_URL} class="site-title" title={channel?.title}>
        {channel.title}
      </a>
    </div>
  </div>
</List>
