---
import Layout from '../../layouts/base.astro'
import Header from '../../components/header.astro'
import { getChannelInfo } from '../../lib/telegram'
import { getUiLabels } from '../../lib/i18n'
import { getChannelOptions, getChannelSetting, getChannelsSetting, getFilterKeywordsSetting } from '../../lib/settings'

const channel = await getChannelInfo(Astro)
const labels = getUiLabels(Astro)

channel.seo = {
  title: labels.settingsTitle,
  noindex: true,
}

const channelSetting = getChannelSetting(Astro)
const channelsSetting = getChannelsSetting(Astro)
const channelOptions = getChannelOptions(Astro)
const channelList = channelOptions.list
const currentChannel = channelOptions.current
const currentChannelKey = currentChannel?.toLowerCase() ?? ''
const filterSetting = getFilterKeywordsSetting(Astro)
const channelLocked = channelSetting.source === 'env'
const channelsLocked = channelsSetting.source === 'env'
const filterLocked = filterSetting.source === 'env'
const saved = Astro.url.searchParams.get('saved') === '1'
---

<Layout channel={channel}>
  <slot name="header">
    <Header channel={channel} />
  </slot>

  <div class="section-title">{labels.settingsTitle}</div>

  {saved && <div class="notice">{labels.save} ✔</div>}

  <form class="settings-form" action="/settings/save" method="post">
    <div class="form-field">
      <label class="form-label" for="channels-input">{labels.channels}</label>
      <div
        class={`tag-input ${channelsLocked ? 'is-locked' : ''}`}
        data-channel-tags
        data-channel-locked={channelLocked ? 'true' : 'false'}
        data-list-locked={channelsLocked ? 'true' : 'false'}
        data-remove-label={labels.remove}
      >
        <div class="tag-input-list">
          {channelList.map((name) => (
            <div class={`channel-tag ${name.toLowerCase() === currentChannelKey ? 'active' : ''}`} data-channel={name}>
              <button
                type="button"
                class="channel-tag-select"
                aria-pressed={name.toLowerCase() === currentChannelKey ? 'true' : 'false'}
                disabled={channelLocked}
              >
                {name}
              </button>
              {
                !channelsLocked ? (
                  <button
                    type="button"
                    class="channel-tag-remove"
                    aria-label={`${labels.remove} ${name}`}
                    disabled={channelLocked && name.toLowerCase() === currentChannelKey}
                  >
                    ×
                  </button>
                ) : null
              }
            </div>
          ))}
        </div>
        <input
          id="channels-input"
          type="text"
          class="tag-input-field"
          placeholder={labels.channelsPlaceholder}
          disabled={channelsLocked}
          autocomplete="off"
        />
      </div>
      <input
        type="hidden"
        id="channels-hidden"
        name="channels"
        value={channelList.join(',')}
        disabled={channelsLocked}
      />
      <input
        type="hidden"
        id="channel-current"
        name="channel"
        value={currentChannel}
        disabled={channelLocked}
      />
      {channelsLocked && <div class="form-hint">{labels.controlledByEnv}</div>}
      {channelLocked && <div class="form-hint">{labels.channelControlledByEnv}</div>}
      <div class="form-hint">{labels.channelsHint}</div>
    </div>

    <div class="form-field">
      <label class="form-label" for="keywords-input">{labels.keywords}</label>
      <textarea
        id="keywords-input"
        name="keywords"
        rows="4"
        placeholder={labels.keywordsPlaceholder}
        disabled={filterLocked}
      >
        {filterSetting.value}
      </textarea>
      {filterLocked && <div class="form-hint">{labels.controlledByEnv}</div>}
      <div class="form-hint">{labels.keywordsHint}</div>
    </div>

    <button class="primary-button" type="submit">{labels.save}</button>
  </form>

  <div class="settings-panel">
    <div class="section-title">{labels.appearanceTitle}</div>
    <div class="settings-card">
      <div class="form-field">
        <div class="form-label">{labels.mode}</div>
        <div class="form-hint">{labels.modeHint}</div>
        <div class="theme-switch">
          <button class="switch-chip" type="button" data-mode-value="light" aria-pressed="false">
            {labels.light}
          </button>
          <button class="switch-chip" type="button" data-mode-value="dark" aria-pressed="false">
            {labels.dark}
          </button>
          <button class="switch-chip" type="button" data-mode-value="system" aria-pressed="false">
            {labels.system}
          </button>
        </div>
      </div>

      <div class="form-field">
        <div class="form-label">{labels.layout}</div>
        <div class="form-hint">{labels.layoutHint}</div>
        <div class="theme-switch">
          <button class="switch-chip" type="button" data-layout-value="card" aria-pressed="false">
            {labels.layoutCard}
          </button>
          <button class="switch-chip" type="button" data-layout-value="grid" aria-pressed="false">
            {labels.layoutGrid}
          </button>
          <button class="switch-chip" type="button" data-layout-value="masonry" aria-pressed="false">
            {labels.layoutMasonry}
          </button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    ;(() => {
      const wrapper = document.querySelector('[data-channel-tags]')
      if (!wrapper)
        return

      const listEl = wrapper.querySelector('.tag-input-list')
      const input = wrapper.querySelector('.tag-input-field')
      const hiddenChannels = document.getElementById('channels-hidden')
      const hiddenCurrent = document.getElementById('channel-current')
      const channelLocked = wrapper.dataset.channelLocked === 'true'
      const listLocked = wrapper.dataset.listLocked === 'true'
      const removeLabel = wrapper.dataset.removeLabel || '移除'

      const parseList = (value = '') =>
        value
          .split(/[\n,;]+/g)
          .map((item) => item.trim())
          .filter(Boolean)

      let channels = parseList(hiddenChannels?.value ?? '')
      if (!channels.length && hiddenCurrent?.value) {
        channels = [hiddenCurrent.value]
      }

      const syncHidden = () => {
        if (hiddenChannels) {
          hiddenChannels.value = channels.join(',')
        }
        if (hiddenCurrent && !hiddenCurrent.value && channels.length) {
          hiddenCurrent.value = channels[0]
        }
        updateActive()
      }

      const updateActive = () => {
        const current = (hiddenCurrent?.value || '').toLowerCase()
        listEl?.querySelectorAll('.channel-tag')?.forEach((tag) => {
          const name = (tag.dataset.channel || '').toLowerCase()
          const active = name === current && current.length > 0
          tag.classList.toggle('active', active)
          const selectButton = tag.querySelector('.channel-tag-select')
          if (selectButton) {
            selectButton.setAttribute('aria-pressed', active)
          }
          const removeButton = tag.querySelector('.channel-tag-remove')
          if (removeButton && channelLocked) {
            removeButton.disabled = active
          }
        })
      }

      const createTag = (name) => {
        const tag = document.createElement('div')
        tag.className = 'channel-tag'
        tag.dataset.channel = name

        const selectButton = document.createElement('button')
        selectButton.type = 'button'
        selectButton.className = 'channel-tag-select'
        selectButton.textContent = name
        selectButton.disabled = channelLocked
        tag.append(selectButton)

        if (!listLocked) {
          const removeButton = document.createElement('button')
          removeButton.type = 'button'
          removeButton.className = 'channel-tag-remove'
          removeButton.setAttribute('aria-label', `${removeLabel} ${name}`)
          removeButton.textContent = '×'
          tag.append(removeButton)
        }

        listEl?.append(tag)
      }

      const addChannels = (values) => {
        let changed = false
        values.forEach((value) => {
          const normalized = value.trim()
          if (!normalized)
            return
          if (channels.some((item) => item.toLowerCase() === normalized.toLowerCase()))
            return
          channels.push(normalized)
          createTag(normalized)
          changed = true
        })
        if (changed)
          syncHidden()
      }

      const removeChannel = (name) => {
        channels = channels.filter((item) => item.toLowerCase() !== name.toLowerCase())
        if (hiddenCurrent && hiddenCurrent.value.toLowerCase() === name.toLowerCase()) {
          hiddenCurrent.value = channels[0] || ''
        }
        syncHidden()
      }

      const setCurrent = (name) => {
        if (channelLocked || !hiddenCurrent)
          return
        hiddenCurrent.value = name
        updateActive()
      }

      if (!listLocked && input) {
        const commitInput = () => {
          const value = input.value
          if (!value)
            return
          const values = parseList(value)
          if (!values.length)
            return
          addChannels(values)
          input.value = ''
        }

        input.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ',' || event.key === ';') {
            event.preventDefault()
            commitInput()
          }
        })

        input.addEventListener('input', () => {
          if (/[\n,;]+/.test(input.value))
            commitInput()
        })

        input.addEventListener('blur', commitInput)
      }

      listEl?.addEventListener('click', (event) => {
        const selectButton = event.target.closest('.channel-tag-select')
        if (selectButton) {
          setCurrent(selectButton.textContent || '')
          return
        }

        const removeButton = event.target.closest('.channel-tag-remove')
        if (removeButton) {
          const tag = removeButton.closest('.channel-tag')
          const name = tag?.dataset.channel
          if (!name)
            return
          tag.remove()
          removeChannel(name)
        }
      })

      syncHidden()
    })()
  </script>
</Layout>
