---
import List from '../../components/list.astro'
import SearchHighlight from '../../components/search-highlight.astro'
import { getChannelInfo } from '../../lib/telegram'
import { getUiLabels } from '../../lib/i18n'

const q = Astro.url.searchParams.get('q') || ''
const labels = getUiLabels(Astro)
const channel = await getChannelInfo(Astro, q ? { q } : {})

if (!q) {
  channel.posts = []
}

channel.seo = {
  title: q || labels.search,
  noindex: true,
}
---

<List channel={channel} before={false} after={false} query={q} />
<SearchHighlight term={q} />
